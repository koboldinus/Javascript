<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Millionenshow Quiz</title>
</head>
<body>
<h1>Millionenshow</h1>
<!-- Überschrift -->
<div id="frage">Drücke "Neue Frage"</div>
<!-- Hier wird die aktuelle Frage angezeigt -->
<!-- Antwort-Buttons -->
<button onclick="antwort(0)" id="a"></button>
<button onclick="antwort(1)" id="b"></button>
<button onclick="antwort(2)" id="c"></button>
<button onclick="antwort(3)" id="d"></button>
<br><br>
<!-- Button, um eine neue Frage zu laden -->
<button onclick="neueFrage()">Neue Frage</button>
<!-- Hier wird das Ergebnis angezeigt -->
<p id="ergebnis"></p>
<script>
 
        // Array von Fragen mit Antwortmöglichkeiten und dem Index der richtigen Antwort
 
        let fragen = [
 
            {
 
                frage: "Was bedeutet HTML?",
 
                antworten: ["Hyper Text Markup Language", "High Text Machine Language", "Hyperlinks and Text Machine Language", "Home Tool Markup Language"],
 
                richtig: 0
 
            },
 
            {
 
                frage: "Welche Sprache läuft im Browser?",
 
                antworten: ["Python", "Java", "JavaScript", "C++"],
 
                richtig: 2
 
            },
 
            {
 
                frage: "Wie viele Planeten hat unser Sonnensystem?",
 
                antworten: ["7", "8", "9", "10"],
 
                richtig: 1
 
            }
 
        ];
 
        let aktuelleFrage; // speichert die aktuelle Frage
 
        // Funktion zum Laden einer neuen Frage
 
        function neueFrage() {
 
            let zufall = Math.floor(Math.random() * fragen.length);
 
            aktuelleFrage = fragen[zufall]; // aktuelle Frage speichern
 
            // Frage anzeigen
 
            document.getElementById("frage").innerText = aktuelleFrage.frage;
 
            // Antwortmöglichkeiten in Buttons setzen
 
            document.getElementById("a").innerText = "A: " + aktuelleFrage.antworten[0];
 
            document.getElementById("b").innerText = "B: " + aktuelleFrage.antworten[1];
 
            document.getElementById("c").innerText = "C: " + aktuelleFrage.antworten[2];
 
            document.getElementById("d").innerText = "D: " + aktuelleFrage.antworten[3];
 
            // Ergebnisbereich leeren
 
            document.getElementById("ergebnis").innerText = "";
 
        }
 
        // Funktion, die aufgerufen wird, wenn eine Antwort angeklickt wird
 
        function antwort(nummer) {
 
            if (nummer == aktuelleFrage.richtig) {
 
                document.getElementById("ergebnis").innerText = "Richtig!";
 
            } else {
 
                document.getElementById("ergebnis").innerText = "Falsch!";
 
            }
 
        }
</script>
</body>
</html>
