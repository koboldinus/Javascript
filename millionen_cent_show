<!DOCTYPE html>
<html lang="de">
<!-- Sprache -->
<head>
<style>
        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            background-color:cornflowerblue
        }
</style>
<!-- Stil Mittig untereinander -->
<meta charset="UTF-8">
<!-- Buchtaben Zahlenpack -->
<title>Millionenshow Quiz</title>
</head>
<body>
<h1>Millionenshow</h1>
<!-- Überschrift -->
<div id="frage">Drücke "Neue Frage"</div>
<!-- Id für funktion weiter unten-->
<br><br>
 
    <button style="width: 300px; height: 50px;" onclick="antwort(0)" id="a"></button>  <!-- breit höhe Kästchen -->
<br><br>   <!-- Zwei Zeilenumbrüche -->
 
    <button style="width: 300px; height: 50px;" onclick="antwort(1)" id="b"></button>
<br><br>
 
    <button style="width: 300px; height: 50px;" onclick="antwort(2)" id="c"></button>
<br><br>
 
    <button style="width: 300px; height: 50px;" onclick="antwort(3)" id="d"></button>
<!-- Button Wenn geklickt Fubktion antwort stelle 3-->
<br><br>
 

<button onclick="neueFrage()">Neue Frage</button>
<!-- Neu Frage -->
<p id="ergebnis"></p>
<br><br>
 
    <button style="width: 200px; height: 50px;" onclick="aussteigen()">Aussteigen</button>
<br><br>
<!-- Aussteigen -->
 
    <script>
        // Beginn Javascript
 
        z = ["0", "100", "200", "300", "400", "500", "1000", "2500", "5000", "10000", "15000", "30000", "75000", "150000", "300000", "1000000 Watschen gewonnen"]
        let x = 0;
 
        let fragen = [
 
            {
                frage: "Wie heißt der größte Ozean der Erde?",
                antworten: ["Atlantik", "Indischer Ozean", "Pazifischer Ozean", "Arktischer Ozean"],
                richtig: 2
            },
 
            {
                frage: "Wie heißt die Währung in Japan?",
                antworten: ["Yuan", "Won", "Yen", "Dollar"],
                richtig: 2
            },
 
            {
                frage: "Wie viele Planeten hat unser Sonnensystem?",
                antworten: ["7", "8", "9", "10"],
                richtig: 1
            },
 
            {
                frage: "Welches Land hat die meisten Zeitzonen?",
                antworten: ["USA", "Russland", "Frankreich", "China"],
                richtig: 2
            },
 
            {
                frage: "Wann entdeckte Christoph Kolumbus Amerika?",
                antworten: ["1809", "1397", "2000", "1492"],
                richtig: 3
 
            },
 
            {
                frage: "Welcher Spruch ist nicht in Mechanik bekannt?",
                antworten: ["Ihr wart ja 2 Klassen", "Wie soll das konstant sein", "Was ist B und was ist H", "Arktischer Ozean"],
                richtig: 3
            },
 
            {
                frage: "Wer beeintruckt mit seiner besonderen Anwesenheit?",
                antworten: ["Marcel", "Oli", "Leo", "Moni"],
                richtig: 0
            },
 
            {
                frage: "Wie lautet das Ergebnis der Rechnung 2x2+2/2-2?",
                antworten: ["3", "4", "1", "2"],
                richtig: 0
            },
 
            {
                frage: "Welche Bildschirmzeit hat der Noah Fischer durchschnitlich?",
                antworten: ["6 h", "8 h", "10 h", "Die Länge des Schultages"],
                richtig: 3
            },
 
            {
                frage: "Wie viele Spieler stehen bei einem offiziellen Basketballspiel pro Mannschaft gleichzeitig auf dem Feld?",
                antworten: ["5", "6", "7", "8"],
                richtig: 0
 
            },
 
            {
                frage: "Welche Norm hatte die Augenschraube?",
                antworten: ["DIN A4", "DIN 444", "ISO 9001", "ISO 8601"],
                richtig: 1
            },
 
            {
                frage: "Was ist unbekannt für HTL Schüler?",
                antworten: ["Freizeit", "Verzweiflung", "Depression", "Hass"],
                richtig: 0
 
            },
 
            {
                frage: "Wie nennt man die Angst vor langen Wörtern?",
                antworten: ["Kurzwortphobie", "Gigantophonismus", "Hippopotomonstrosesquippedaliophobie", "Alphabet-Aversion"],
                richtig: 2
 
            },
 
            {
                frage: "Woran erkennt man bei Pinguinen, dass sie gerade ein „Geschäft“ verrichtet haben?",
                antworten: ["Sie machen einen Freudensprung", "Sie schießen ihren Kot mit Hochdruck bis zu 40 cm weit weg", "Sie verbeugen sich vor ihrem Partner", "Sie fangen an zu singen "],
                richtig: 1
 
            },
 
            {
                frage: "Wie viele antworten gibt es bei Englisch, wenn in der Angabe steht: Es gibt mehrere korrekte Antworten",
                antworten: ["1", "2", "Je nach angabe", "3"],
                richtig: 0
 
            },
 

        ]; //Fragen und Antworten werden im Array gespeichert
 
        let aktuelleFrage; // Definiert aktuelle Frage
 
        // 🔧 NEU: Funktion zum Aktivieren/Deaktivieren der Buttons
        function setButtonsDisabled(status) {
            document.getElementById("a").disabled = status;
            document.getElementById("b").disabled = status;
            document.getElementById("c").disabled = status;
            document.getElementById("d").disabled = status;
        }
 
        function neueFrage() {
            // Funktion zum Laden einer neuen Frage, wenn Button geklickt
 
            let zufall = Math.floor(Math.random() * fragen.length);
            //Math.floor das Zahl immer abgerundet wird
            //Math random zufallszahl * Fragenanzahl
 
            aktuelleFrage = fragen[zufall];  //DIe Frage der Zufallszahl= aktuelle Frage
 
            fragen.splice(zufall, 1)
            // entfernt die Frage aus dem Array
            // 1 ist die Anzahl der entfernten Fragen
 

            document.getElementById("frage").innerText = aktuelleFrage.frage;
            //inner Text = Schreibe Text der aktuellen Frage hin
            //über document kann man alles im Dokument suchen
 
            document.getElementById("a").innerText = "A: " + aktuelleFrage.antworten[0];
            document.getElementById("b").innerText = "B: " + aktuelleFrage.antworten[1];
            document.getElementById("c").innerText = "C: " + aktuelleFrage.antworten[2];
            document.getElementById("d").innerText = "D: " + aktuelleFrage.antworten[3];
            //Funktion von Button definieren über Id
            // A: + Antwortstelle 1 usw.
 
            document.getElementById("ergebnis").innerText = "";
 
            // Ergebnisbereich leeren wenn neue Frage kommt
            // Funktion, die aufgerufen wird, wenn eine Antwort angeklickt wird
            // 🔧 NEU: Buttons wieder aktivieren
            setButtonsDisabled(false);
        }
 
        function antwort(nummer) {
 
            // 🔧 NEU: Buttons deaktivieren nach Klick
            setButtonsDisabled(true);
 
            if (nummer == aktuelleFrage.richtig) {
                x++;
                console.log(z[x]);
                document.getElementById("ergebnis").innerText = z[x];
            }
 
            else {
                document.getElementById("ergebnis").innerText = "Falsch!";
                alert("Du hast es Falsch. Willst du es erneut versuchen?");
                location.reload();
            }
        }
 
        function aussteigen() {
            alert("Du hast " + z[x] +  " Watschen gewonnen");
            location.reload()
        }
 
    </script>
</body>
</html>
